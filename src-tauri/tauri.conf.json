{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "글 요약 분석기",
  "version": "0.1.0",
  "identifier": "com.contentsummaryanalyzer.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "글 요약 분석기",
        "width": 1440,
        "height": 960,
        "minWidth": 1200,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}
